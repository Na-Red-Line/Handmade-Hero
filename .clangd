CompileFlags:
  Add:
    - -xc++
    - -std=gnu++14
    - -fno-exceptions
    - -fno-rtti
    - -Wall
    - -Wextra
    - -Wshadow
    - -Wno-unused-parameter
    - -Wno-unused-variable
    - -Wno-unused-function
    - -Wno-missing-field-initializers
    - -DHANDMADE_INTERNAL=1
    - -DRECORD=1

Index:
  Background: Build

InlayHints:
  Enabled: No

Diagnostics:
  Suppress:
    - unused-includes
